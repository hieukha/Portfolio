# MongoDB connection string (local dev example)
MONGODB_URI=mongodb://localhost:27017/portfolio

# NextAuth / Auth.js secret — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=

# Admin login (consumed by `npm run create-admin` to seed the admin user)
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=your-strong-password

# AI chatbot (Gemini for chat + embeddings, Qdrant for vector search over blog/publication content)
# Get a free Gemini key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=
# Qdrant: run locally with Docker (see README) or point at Qdrant Cloud
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=portfolio-ai
